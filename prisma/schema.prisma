// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  GITHUB
  MEDIUM
  REDDIT
  PRODUCTHUNT
  HACKERNEWS
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  tools     Tool[]
  createdAt DateTime @default(now())

  @@index([slug])
}

model Tool {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?    @db.Text
  url         String
  imageUrl    String?
  sourceType  SourceType
  sourceId    String
  author      String?
  stars       Int?
  upvotes     Int?
  publishedAt DateTime
  collectedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  tags       Tag[]

  @@unique([sourceType, sourceId])
  @@index([publishedAt(sort: Desc)])
  @@index([categoryId])
  @@index([sourceType])
  @@index([slug])
}
