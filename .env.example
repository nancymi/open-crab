# Database URL (automatically set by Vercel Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/opencrab"

# GitHub API Token (REQUIRED)
# Get from: https://github.com/settings/tokens
# Scopes needed: public_repo
GITHUB_TOKEN="ghp_your_github_token_here"

# Cron Secret (REQUIRED for production)
# Generate with: openssl rand -base64 32
CRON_SECRET="your-random-secret-key-here"

# Product Hunt API Key (OPTIONAL)
# Get from: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_API_KEY=""

# Reddit API Credentials (OPTIONAL - can use public JSON endpoints)
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# Base URL for your deployment (OPTIONAL)
# Used for RSS feed generation
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
